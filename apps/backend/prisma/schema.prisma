// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id
  email         String         @unique
  name          String?
  folders       Folder[]
  files         File[]
  storage       UserStorage?
  notifications Notification[]
  apiKeys       ApiKey[]
}

model UserStorage {
  id             Int       @id @default(autoincrement())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalStorage   Float     @default(0) // stored in MB
  usedStorage    Float     @default(0) // stored in MB
  plan           String    @default("free") // "free", "trial", "pro", "business"
  trialExpiresAt DateTime?
  hasUsedTrial   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderTree")
  files    File[]

  starred  Boolean  @default(false)
  trashed  Boolean  @default(false)

  // Sharing features
  isPublic          Boolean       @default(false)
  publicCanUpload   Boolean       @default(false)
  showOwnerName     Boolean       @default(true)
  showOwnerEmail    Boolean       @default(true)
  shares            FolderShare[]
  apiKeys           ApiKey[]

  @@index([ownerId])
  @@index([parentId])
}

model FolderShare {
  id        String   @id @default(uuid())
  folderId  String
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  email     String
  canUpload Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([folderId, email])
  @@index([folderId])
  @@index([email])
}

model File {
  id        String   @id @default(uuid())
  name      String
  s3Url     String
  sizeMb    Float    @default(0) // size in MB
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  starred Boolean @default(false)
  trashed Boolean @default(false)
  processingStatus String? // "processing", "completed", "failed" or null if not a video
  decodingEnabled Boolean @default(true)
  thumbnailUrl String?

  downloads FileDownload[]
  subtitles SubtitleTrack[]
  audioTracks AudioTrack[]

  @@index([ownerId])
  @@index([folderId])
}

model SubtitleTrack {
  id        String   @id @default(uuid())
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  label     String
  language  String
  s3Url     String
  createdAt DateTime @default(now())

  @@index([fileId])
}

model AudioTrack {
  id        String   @id @default(uuid())
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  label     String
  language  String
  s3Url     String
  createdAt DateTime @default(now())

  @@index([fileId])
}

model FileDownload {
  id           String   @id @default(uuid())
  fileId       String
  file         File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId       String
  downloadedAt DateTime @default(now())

  @@index([fileId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model ApiKey {
  id         String   @id @default(uuid())
  name       String
  keyId      String   @unique
  secretHash String
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  folderId   String?
  folder     Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([keyId])
  @@index([userId])
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  discountPercent Int      @default(100)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
}


