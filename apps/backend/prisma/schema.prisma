// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id      String       @id
  email   String       @unique
  name    String?
  folders Folder[]
  files   File[]
  storage UserStorage?
}

model UserStorage {
  id           Int      @id @default(autoincrement())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalStorage Float    @default(0) // stored in MB
  usedStorage  Float    @default(0) // stored in MB
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderTree")
  files    File[]

  starred  Boolean  @default(false)
  trashed  Boolean  @default(false)

  // Sharing features
  isPublic          Boolean       @default(false)
  publicCanUpload   Boolean       @default(false)
  showOwnerName     Boolean       @default(true)
  showOwnerEmail    Boolean       @default(true)
  shares            FolderShare[]

  @@index([ownerId])
  @@index([parentId])
}

model FolderShare {
  id        String   @id @default(uuid())
  folderId  String
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  email     String
  canUpload Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([folderId, email])
  @@index([folderId])
  @@index([email])
}

model File {
  id        String   @id @default(uuid())
  name      String
  s3Url     String
  sizeMb    Float    @default(0) // size in MB
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  starred Boolean @default(false)
  trashed Boolean @default(false)

  downloads FileDownload[]

  @@index([ownerId])
  @@index([folderId])
}

model FileDownload {
  id           String   @id @default(uuid())
  fileId       String
  file         File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId       String
  downloadedAt DateTime @default(now())

  @@index([fileId])
  @@index([userId])
}

